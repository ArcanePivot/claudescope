{
  "name": "claudescope",
  "version": "1.0.1",
  "description": "A local-first Claude Code usage and pressure dashboard.",
  "private": false,
  "type": "commonjs",
  "scripts": {
    "build:frontend": "tsc -p tsconfig.json",
    "generate": "go run ./generator/cmd/claudescope generate",
    "build:generator": "go build -trimpath -ldflags \"-s -w -buildid= -X main.Version=1.0.1\" -o bin/claudescope ./generator/cmd/claudescope",
    "build": "npm run build:frontend && npm run build:generator",
    "release:local": "bash scripts/build-release.sh",
    "verify": "npm run build:frontend && node verify_responsive.js"
  },
  "devDependencies": {
    "playwright": "^1.56.0",
    "typescript": "^5.9.3"
  }
}
