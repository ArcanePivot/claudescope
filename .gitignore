.DS_Store
.env
.env.*

node_modules/
__pycache__/
*.py[cod]

# Local Claude Code usage export. This can contain private project names,
# session ids, timestamps, quota status, and usage patterns.
data.js
data.raw.js
!data.sample.js
.claudescope-cache.json
.claudescope-cache.json.stamp
claudescope-generator
claudescope-generator.exe
claudescope-darwin-arm64
claudescope-windows-amd64.exe
dist/

# Compiled CLI artifacts. Use `npm run build` to regenerate locally;
# release zips already bundle prebuilt binaries.
bin/claudescope
bin/claudescope.exe
bin/claudescope-*

# Internal process docs (phase / audit / review). Kept in a private mirror
# repo, not in this public repo.
/docs/phase-*.md
/docs/v1.0-*.md
/docs/v1.1-*.md
/docs/*review*.md
/docs/*audit*.md
/docs/internal/

# Local upstream reference (CodexScope fork source). Not part of this repo.
temp-codexscope/

# Local visual audit artifacts.
*.png
*.webp
*.jpg
*.jpeg
!assets/
!assets/**

# Schema probe outputs. probe-real.json contains real model distribution
# from the user's own ~/.claude/projects/, which must never be checked in.
probe-real.json
probe-fixtures.json
probe-*.json
